{
  "expo": {
    "name": "voice-chat-app",
    "slug": "voice-chat-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.voicechatapp",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Приложению нужен доступ к микрофону для работы рации между байкерами.",
        "NSLocalNetworkUsageDescription": "Нужен доступ к локальной сети для поиска других устройств без интернета.",
        "NSBonjourServices": [
          "_moto-intercom._udp.local."
        ]
      }
    },
    "android": {
      "gradleCommand": ":app:assembleDebug",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.anonymous.voicechatapp",
      "permissions": [
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "CAMERA",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "CHANGE_WIFI_MULTICAST_STATE"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "minSdkVersion": 24,
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "extraGradleProperties": {
              "kotlin.plugin.suppressKotlinVersionCompatibilityCheck": "true"
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "fbb57b22-f495-4cee-af03-200087946956"
      }
    }
  }
}